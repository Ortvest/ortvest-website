# Public URL of this site (used for Stripe cancel_url when subscribing to CMS)
NEXT_PUBLIC_SITE_URL=http://localhost:5173

# Ortvest CMS origin — server-side proxy calls this to create Stripe Checkout.
# In development, defaults to http://localhost:3200 if unset.
ORTVEST_CMS_API_URL=http://localhost:3200

# MongoDB (contact form, etc.)
MONGODB_URI=mongodb+srv://user:PASS@cluster.mongodb.net/
